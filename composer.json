{
    "name": "magematch/module-customer-uuid",
    "description": "Assigns a unique UUID v4 attribute to every Magento 2 customer, exposes it via GraphQL, and displays it read-only in the admin customer grid and form.",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "magento/framework": "*",
        "magento/module-customer": "*",
        "magento/module-eav": "*",
        "magento/module-graph-ql": "*",
        "magento/module-customer-graph-ql": "*",
        "magento/module-ui": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Magematch\\CustomerUuid\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Magematch\\CustomerUuid\\Test\\": "Test/"
        }
    }
}
